# Copy this file to .env and fill in real values.
# Only fill in the section for the provider(s) you actually use.
# Provider choice is set in Settings → Email and Settings → SMS — not here.
# This file only holds credentials (secrets that must never go in the database).

# ──────────────────────────────────────────────────────────────────────────────
# Core
# ──────────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────
# Local dev (no setup needed) → SQLite file in instance/
DATABASE_URL=sqlite:///techpro.db
#
# Production → Neon / PostgreSQL:
# DATABASE_URL=postgresql://user:password@ep-something.us-east-2.aws.neon.tech/techpro_crm?sslmode=require

# ──────────────────────────────────────────────────────────────────────────────
# Shop defaults (used to seed Settings on first run)
# ──────────────────────────────────────────────────────────────────────────────
SHOP_NAME=Tech-Pro+ Repairs
SHOP_PROVINCE=ON
SHOP_CURRENCY=$

# ──────────────────────────────────────────────────────────────────────────────
# Email — shared sender config (used by ALL email providers)
# ──────────────────────────────────────────────────────────────────────────────
EMAIL_FROM_ADDRESS=receipts@yourshop.com
EMAIL_FROM_NAME=Your Shop Name

# ──────────────────────────────────────────────────────────────────────────────
# Email provider credentials — only fill the section for your chosen provider
# ──────────────────────────────────────────────────────────────────────────────

# SMTP (Gmail, Outlook, Zoho, any SMTP relay)
# Gmail and Outlook need an "App Password", not your normal account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_SSL=false

# SendGrid
SENDGRID_API_KEY=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us

# Postmark
POSTMARK_SERVER_TOKEN=

# Amazon SES (also requires: pip install boto3)
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, and AWS_REGION are shared with SNS below.

# ──────────────────────────────────────────────────────────────────────────────
# SMS provider credentials — only fill the section for your chosen provider
# ──────────────────────────────────────────────────────────────────────────────

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Vonage (formerly Nexmo)
VONAGE_API_KEY=
VONAGE_API_SECRET=

# MessageBird
MESSAGEBIRD_API_KEY=

# Telnyx
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=

# Amazon SNS (also requires: pip install boto3)
# Shared with SES above if you're using both AWS services:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
